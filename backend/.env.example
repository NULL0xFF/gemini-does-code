# Database Configuration (MariaDB for default profile)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ark_resolver
DB_USER=root
DB_PASSWORD=secret

# JWT Configuration
# Use a secure random string (at least 256-bit / 32 characters) for HMAC-SHA256
JWT_SECRET=your-256-bit-secret-key-goes-here-change-me

# Frontend URL (for CORS and OAuth Redirects)
FRONTEND_URL=http://localhost:5173

# Discord OAuth2 Configuration
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=${FRONTEND_URL}/login/callback
