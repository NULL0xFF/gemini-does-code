# GitHub username for GHCR image references in docker-compose
GITHUB_USERNAME=your-github-username

# MariaDB
DB_ROOT_PASSWORD=changeme_root
DB_NAME=ark
DB_USER=ark
DB_PASSWORD=changeme

# Spring Boot datasource — DB_HOST must match the docker-compose service name
DB_HOST=db
DB_PORT=3306

# Spring Boot JPA — use 'validate' in production; 'update' only for first-time setup
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# JWT signing secret (HMAC-SHA256, use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# Discord OAuth2 application credentials
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://yourserver.com/login/callback

# Frontend URL (used by backend for CORS and OAuth2 redirect)
FRONTEND_URL=http://yourserver.com
