# GitHub username for GHCR image references in docker-compose
GITHUB_USERNAME=your-github-username

# MariaDB
DB_ROOT_PASSWORD=changeme_root
DB_NAME=ark
DB_USER=ark
DB_PASSWORD=changeme

# Spring Boot datasource (connects to the db service above)
SPRING_DATASOURCE_URL=jdbc:mariadb://db:3306/ark
SPRING_DATASOURCE_USERNAME=ark
SPRING_DATASOURCE_PASSWORD=changeme

# Spring Boot JPA — set to validate or none in production
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT signing secret (HMAC-SHA256, use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# Discord OAuth2 application credentials
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://yourserver.com/auth/callback
